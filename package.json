{
  "name": "last-successful-commit-action",
  "version": "1.0.0",
  "description": "GitHub action for identifying the last successful commit for a given workflow and branch",
  "main": "dist/index.cjs",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "prepare": "husky",
    "build": "pnpm run typecheck && pnpm run bundle && pnpm run license",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/index.cjs --sourcemap --minify --legal-comments=external",
    "license": "node scripts/write-licenses.mjs",
    "typecheck": "tsc --noEmit"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/node": "^24.12.4",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1"
  }
}
